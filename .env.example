# ── Supabase (Vite frontend) ───────────────────────────────────────────────────
# Alle publieke Vite-variabelen moeten beginnen met VITE_
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# ── Anthropic / Claude (indien direct vanuit frontend aangeroepen) ─────────────
# LET OP: dit exposeert de key in de browser-bundle — bij voorkeur via backend
VITE_ANTHROPIC_API_KEY=

# ── Backend webhook URL (optioneel, indien frontend backend aanroept) ─────────
# Vul in na Railway-deploy (bijv. https://talentlens-backend.up.railway.app)
VITE_BACKEND_URL=
