# ── Supabase ──────────────────────────────────────────────────────────────────
# Publiek project-URL (zelfde als frontend)
SUPABASE_URL=https://<project-ref>.supabase.co

# Service-role key (GEHEIM — nooit committen, omzeilt RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Webhook beveiliging ───────────────────────────────────────────────────────
# Willekeurige string; identiek instellen in Supabase Database Webhook header:
#   Header naam:  x-webhook-secret
#   Header waarde: <zelfde waarde als hieronder>
WEBHOOK_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
# Railway stelt PORT automatisch in; lokaal is 3001 handig
PORT=3001

# ── Candidate Enrichment APIs ─────────────────────────────────────────────────
# Kantoor-postcode voor reistijdberekening (Mapbox)
OFFICE_ZIP_CODE=1012AB

# Mapbox Directions + Geocoding API
# https://account.mapbox.com/ → Tokens
MAPBOX_ACCESS_TOKEN=

# Brandfetch REST API (bedrijfslogo's)
# https://app.brandfetch.io/ → API Keys
BRANDFETCH_API_KEY=

# Adzuna Jobs API (salarissen)
# https://developer.adzuna.com/ → Register
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
